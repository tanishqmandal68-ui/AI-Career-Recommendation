# Groq API Configuration
GROQ_API_KEYS=["your_groq_api_key_here"]
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_SAFE_TOKEN_QUOTA=500000

# Moonshot (Kimi) Configuration
MOONSHOT_API_KEYS=["your_moonshot_api_key_here"]
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_SAFE_TOKEN_QUOTA=1000000

# OpenRouter Configuration
OPENROUTER_API_KEYS=["your_openrouter_api_key_here"]
OPENROUTER_MODEL=kimi-k2.6
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SAFE_TOKEN_QUOTA=1000000

# Fireworks AI Configuration
FIREWORKS_API_KEYS=["your_fireworks_api_key_here"]
FIREWORKS_MODEL=kimi-k2.6
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_SAFE_TOKEN_QUOTA=1000000

# NVIDIA NIM Configuration
NVIDIA_NIM_API_KEYS=["your_nvidia_nim_api_key_here"]
NVIDIA_NIM_MODEL=kimi-k2.6
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_SAFE_TOKEN_QUOTA=1000000

# Cloudflare Workers Configuration
CLOUDFLARE_WORKERS_API_KEYS=["your_cloudflare_workers_api_key_here"]
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_WORKERS_MODEL=kimi-k2.6
CLOUDFLARE_WORKERS_SAFE_TOKEN_QUOTA=1000000

# OpenAI Configuration (for transcription)
OPENAI_API_KEYS=["your_openai_api_key_here"]
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SAFE_TOKEN_QUOTA=1000000
